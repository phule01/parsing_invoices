# Database Configuration
DB_USER=postgres
DB_PASSWORD=change_this_password_12345
DB_NAME=tool_orc_db
DB_PORT=5433
DATABASE_URL=postgresql://postgres:change_this_password_12345@postgres:5432/tool_orc_db

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Application Settings
DEBUG=False
ENVIRONMENT=development

# Frontend / CORS Configuration (set to your Cloudflare domain for deployment)
FRONTEND_URL=http://localhost:7300
REACT_APP_API_URL=

# JWT Configuration
SECRET_KEY=............
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (SMTP for sending invoices)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Email Listener Configuration (IMAP for receiving invoices)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
SCAN_INTERVAL_SECONDS=300
SCAN_ALL_MAIL=false

# AI Parser Configuration
# GEMINI_API_KEY is now configured via the Web UI (stored in Database)
# Selenium Configuration (for downloading invoices from lookup portals)
SELENIUM_HUB=//////
DOWNLOAD_DIR=/tmp/invoices

# API Client Configuration (email processor to fastapi service)
API_BASE_URL=http://fastapi:8000
API_USERNAME=admin
API_PASSWORD=admin

# Telegram Configuration
# TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID are now configured via the Web UI (stored in Database)
TELEGRAM_WEBHOOK_URL=https://inv.fuvitech.vn/api/telegram/webhook
